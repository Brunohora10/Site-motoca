@model EssenzStore.Models.StoreSettings
@{
    ViewData["Title"] = "Configurações da Loja";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<form asp-action="Configuracoes" asp-controller="Admin" method="post">
    @Html.AntiForgeryToken()
    <div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;align-items:start">

        <!-- Coluna principal -->
        <div>
            <div class="adm-card">
                <p class="adm-card__title">Identidade da Loja</p>
                <div class="adm-form-grid">
                    <div class="form-group">
                        <label>Nome da Loja *</label>
                        <input asp-for="NomeLoja" required />
                    </div>
                    <div class="form-group">
                        <label>Slogan</label>
                        <input asp-for="Slogan" placeholder="Menos pose, mais essência." />
                    </div>
                    <div class="form-group adm-form-grid--full">
                        <label>URL do Logo</label>
                        <input asp-for="LogoUrl" placeholder="https://... ou /images/logo.png" />
                    </div>
                    <div class="form-group adm-form-grid--full">
                        <label>URL do Favicon</label>
                        <input asp-for="FaviconUrl" placeholder="https://... ou /favicon.ico" />
                    </div>
                </div>
            </div>

            <div class="adm-card">
                <p class="adm-card__title">Contato & Redes Sociais</p>
                <div class="adm-form-grid">
                    <div class="form-group">
                        <label>E-mail de Contato</label>
                        <input asp-for="EmailContato" type="email" />
                    </div>
                    <div class="form-group">
                        <label>WhatsApp <small style="color:#666">(só números, ex: 5511999999999)</small></label>
                        <input asp-for="Whatsapp" placeholder="5579999999999" />
                    </div>
                    <div class="form-group">
                        <label>Instagram</label>
                        <input asp-for="Instagram" placeholder="essenzstoree" />
                    </div>
                    <div class="form-group">
                        <label>Facebook</label>
                        <input asp-for="Facebook" placeholder="essenzstoree" />
                    </div>
                    <div class="form-group">
                        <label>TikTok</label>
                        <input asp-for="Tiktok" placeholder="essenzstoree" />
                    </div>
                    <div class="form-group">
                        <label>CNPJ</label>
                        <input asp-for="Cnpj" placeholder="00.000.000/0001-00" />
                    </div>
                </div>
            </div>

            <div class="adm-card">
                <p class="adm-card__title">E-commerce</p>
                <div class="adm-form-grid">
                    <div class="form-group">
                        <label>Frete Grátis a partir de (R$)</label>
                        <input asp-for="FreteGratisValor" type="number" step="0.01" />
                    </div>
                    <div class="form-group">
                        <label>Cupom Primeira Compra</label>
                        <input asp-for="CupomPrimeiraCompra" placeholder="PRIMEIRACOMPRA" style="text-transform:uppercase" />
                    </div>
                    <div class="form-group">
                        <label>Desconto Primeira Compra (%)</label>
                        <input asp-for="PercentualPrimeiraCompra" type="number" min="0" max="100" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Coluna lateral -->
        <div>
            <div class="adm-card">
                <p class="adm-card__title">SEO</p>
                <div class="adm-form-grid" style="grid-template-columns:1fr">
                    <div class="form-group">
                        <label>Meta Description</label>
                        <textarea asp-for="MetaDescription" style="min-height:80px" placeholder="Descrição exibida no Google..."></textarea>
                    </div>
                </div>
            </div>

            <div class="adm-card">
                <p class="adm-card__title">Analytics & Pixel</p>
                <div class="adm-form-grid" style="grid-template-columns:1fr">
                    <div class="form-group">
                        <label>Google Analytics ID</label>
                        <input asp-for="GaTrackingId" placeholder="G-XXXXXXXXXX" />
                    </div>
                    <div class="form-group">
                        <label>Meta Pixel ID</label>
                        <input asp-for="MetaPixelId" placeholder="000000000000000" />
                    </div>
                </div>
            </div>

            <div class="adm-card">
                <button type="submit" class="btn-adm btn-adm--gold" style="width:100%;justify-content:center">
                    <i class="fas fa-save"></i> Salvar Configurações
                </button>
            </div>
        </div>
    </div>
</form>
