@model EssenzStore.Models.ViewModels.AdminProductViewModel
@{
    ViewData["Title"] = "Novo Produto";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section TopbarActions {
    <a href="/admin/produtos" class="btn-adm btn-adm--ghost btn-adm--sm"><i class="fas fa-arrow-left"></i> Voltar</a>
}

<form asp-action="NovoProduto" asp-controller="Admin" method="post">
    @Html.AntiForgeryToken()
    <div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;align-items:start">

        <!-- Coluna principal -->
        <div>
            <div class="adm-card">
                <p class="adm-card__title">Informações Básicas</p>
                <div class="adm-form-grid">
                    <div class="form-group adm-form-grid--full">
                        <label>Nome do Produto *</label>
                        <input asp-for="Nome" />
                        <span asp-validation-for="Nome" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label>Marca *</label>
                        <select asp-for="BrandId">
                            <option value="">Selecione...</option>
                            @foreach (var b in Model.Brands)
                            {
                                <option value="@b.Id">@b.Nome</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Categoria *</label>
                        <select asp-for="CategoryId">
                            <option value="">Selecione...</option>
                            @foreach (var c in Model.Categories)
                            {
                                <option value="@c.Id">@c.Nome</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Preço (R$) *</label>
                        <input asp-for="Preco" type="number" step="0.01" />
                        <span asp-validation-for="Preco" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label>Preço Promocional (R$)</label>
                        <input asp-for="PrecoPromocional" type="number" step="0.01" />
                    </div>
                    <div class="form-group adm-form-grid--full">
                        <label>Descrição Curta</label>
                        <input asp-for="DescricaoCurta" placeholder="Resumo exibido na listagem" />
                    </div>
                    <div class="form-group adm-form-grid--full">
                        <label>Descrição Completa</label>
                        <textarea asp-for="DescricaoCompleta" style="min-height:160px" placeholder="Detalhes completos do produto..."></textarea>
                    </div>
                </div>
            </div>

            <div class="adm-card">
                <p class="adm-card__title">Especificações</p>
                <div class="adm-form-grid">
                    <div class="form-group">
                        <label>Composição</label>
                        <input asp-for="Composicao" placeholder="Ex: 100% algodão" />
                    </div>
                    <div class="form-group">
                        <label>Modelagem</label>
                        <input asp-for="Modelagem" placeholder="Ex: Regular fit" />
                    </div>
                    <div class="form-group adm-form-grid--full">
                        <label>Instruções de Lavagem</label>
                        <input asp-for="InstrucoesLavagem" placeholder="Ex: Lavar à mão, não torcer" />
                    </div>
                </div>
            </div>

            <div class="adm-card">
                <p class="adm-card__title">SEO</p>
                <div class="adm-form-grid">
                    <div class="form-group">
                        <label>Slug (URL)</label>
                        <input asp-for="Slug" placeholder="gerado-automaticamente" />
                    </div>
                    <div class="form-group">
                        <label>Título SEO</label>
                        <input asp-for="SeoTitle" />
                    </div>
                    <div class="form-group adm-form-grid--full">
                        <label>Descrição SEO</label>
                        <textarea asp-for="SeoDescription" style="min-height:70px"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Coluna lateral -->
        <div>
            <div class="adm-card">
                <p class="adm-card__title">Status</p>
                <div style="display:flex;flex-direction:column;gap:0.75rem">
                    <div class="form-check">
                        <input asp-for="Ativo" type="checkbox" id="chkAtivo" />
                        <label for="chkAtivo">Produto ativo (visível na loja)</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="Destaque" type="checkbox" id="chkDestaque" />
                        <label for="chkDestaque">Em destaque na home</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="Lancamento" type="checkbox" id="chkLancamento" />
                        <label for="chkLancamento">Lançamento</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="MaisVendido" type="checkbox" id="chkMaisVendido" />
                        <label for="chkMaisVendido">Mais vendido</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="ProdutoMomento" type="checkbox" id="chkMomento" />
                        <label for="chkMomento">Produto do momento</label>
                    </div>
                </div>
            </div>

            <div class="adm-card" style="margin-top:0">
                <button type="submit" class="btn-adm btn-adm--gold" style="width:100%;justify-content:center">
                    <i class="fas fa-save"></i> Criar Produto
                </button>
                <p style="font-size:.75rem;color:#666;text-align:center;margin-top:.75rem">
                    Após criar, adicione variantes e imagens na edição.
                </p>
            </div>
        </div>
    </div>
</form>
