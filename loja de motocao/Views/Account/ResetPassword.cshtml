@model EssenzStore.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Redefinir Senha";
}

<div class="container" style="min-height:70vh;display:grid;place-items:center;padding:2rem">
    <div class="auth-card" style="max-width:440px;width:100%">
        <div style="text-align:center;margin-bottom:2rem">
            <h1 style="font-size:1.4rem;font-weight:700">Redefinir Senha</h1>
            <p style="color:var(--text3);font-size:.875rem;margin-top:.5rem">Digite sua nova senha abaixo.</p>
        </div>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <div asp-validation-summary="All" class="validation-summary"></div>

            <div style="display:flex;flex-direction:column;gap:1rem">
                <div>
                    <label class="form-label">Nova Senha</label>
                    <input asp-for="NovaSenha" type="password" class="form-input" placeholder="Mínimo 6 caracteres" />
                    <span asp-validation-for="NovaSenha" class="field-error"></span>
                </div>
                <div>
                    <label class="form-label">Confirmar Nova Senha</label>
                    <input asp-for="ConfirmarNovaSenha" type="password" class="form-input" />
                    <span asp-validation-for="ConfirmarNovaSenha" class="field-error"></span>
                </div>
            </div>

            <button type="submit" class="btn btn--primary btn--lg btn--block" style="margin-top:1.5rem">
                <i class="fas fa-lock"></i> Redefinir Senha
            </button>
        </form>

        <p style="text-align:center;margin-top:1.5rem;font-size:.875rem;color:var(--text3)">
            <a href="/Account/Login">← Voltar para o login</a>
        </p>
    </div>
</div>
