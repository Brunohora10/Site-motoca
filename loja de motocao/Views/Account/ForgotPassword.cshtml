@model EssenzStore.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Esqueci minha senha";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1 class="auth-card__title">Recuperar senha</h1>
            <p class="auth-card__sub">Informe seu e-mail e enviaremos as instruções</p>
        </div>

        <form asp-action="ForgotPassword" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation-summary"></div>
            <div class="form-group">
                <label asp-for="Email" class="form-label">E-mail</label>
                <input asp-for="Email" class="form-input" placeholder="seu@email.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <button type="submit" class="btn btn--primary btn--lg btn--block">Enviar instruções</button>
        </form>

        <div class="auth-card__footer">
            <p><a href="/Account/Login">← Voltar ao login</a></p>
        </div>
    </div>
</div>
