@model EssenzStore.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Entrar";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <h1 class="auth-card__title">Bem-vindo de volta</h1>
            <p class="auth-card__sub">Acesse sua conta Essenz Store</p>
        </div>

        <form asp-action="Login" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />

            <div asp-validation-summary="All" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">E-mail</label>
                <input asp-for="Email" class="form-input" placeholder="seu@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <div class="form-label-row">
                    <label asp-for="Senha" class="form-label">Senha</label>
                    <a href="/Account/ForgotPassword" class="form-label-link">Esqueci minha senha</a>
                </div>
                <div class="input-password">
                    <input asp-for="Senha" class="form-input" placeholder="••••••" autocomplete="current-password" id="senhaInput" />
                    <button type="button" class="input-password__toggle" onclick="togglePass('senhaInput', this)">
                        <i class="far fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Senha" class="field-error"></span>
            </div>

            <div class="form-group form-group--inline">
                <label class="checkbox-label">
                    <input asp-for="LembrarMe" type="checkbox" />
                    <span>Lembrar de mim por 30 dias</span>
                </label>
            </div>

            <button type="submit" class="btn btn--primary btn--lg btn--block">Entrar</button>
        </form>

        <div class="auth-card__footer">
            <p>Não tem conta? <a href="/Account/Register">Criar conta grátis</a></p>
        </div>

        <div class="auth-card__admin-hint" style="margin-top:1.5rem;padding:1rem;background:#1a1a1a;border-radius:8px;font-size:0.8rem;color:#888">
            <strong style="color:#d4af37">Admin:</strong> admin@essenzstore.com.br / Admin@123456
        </div>
    </div>
</div>

@section Scripts {
<script>
    function togglePass(id, btn) {
        const input = document.getElementById(id);
        if (input.type === 'password') {
            input.type = 'text';
            btn.innerHTML = '<i class="far fa-eye-slash"></i>';
        } else {
            input.type = 'password';
            btn.innerHTML = '<i class="far fa-eye"></i>';
        }
    }
</script>
}
