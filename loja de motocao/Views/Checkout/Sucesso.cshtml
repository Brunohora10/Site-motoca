@model EssenzStore.Models.ViewModels.OrderSuccessViewModel
@{
    ViewData["Title"] = "Pedido Confirmado!";
    var order = Model.Order;
}

<div class="container" style="padding:5rem 1rem;text-align:center;max-width:700px">
    <div class="success-icon">
        <i class="fas fa-check-circle"></i>
    </div>
    <h1 style="font-size:2rem;margin:1.5rem 0 0.5rem">Pedido Confirmado! 🎉</h1>
    <p style="color:#aaa;font-size:1.1rem">Obrigado pela sua compra. Seu pedido foi recebido com sucesso.</p>

    <div class="success-order-num">
        Pedido <strong>#@order.NumeroPedido</strong>
    </div>

    @if (Model.Payment?.Metodo == EssenzStore.Models.PaymentMethod.Pix && !string.IsNullOrEmpty(Model.QrCodePix))
    {
        <div style="margin:2rem auto;background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:2rem;max-width:400px">
            <h3 style="margin-bottom:1rem"><i class="fab fa-pix" style="color:#4cd964"></i> Pague com PIX</h3>
            <p style="color:#aaa;font-size:0.9rem;margin-bottom:1.5rem">Escaneie o QR Code ou copie o código abaixo:</p>
            <div style="background:#fff;padding:1rem;border-radius:8px;margin-bottom:1rem">
                <p style="color:#000;word-break:break-all;font-family:monospace;font-size:0.8rem">@Model.QrCodePix</p>
            </div>
            <button onclick="navigator.clipboard.writeText('@Model.QrCodePix').then(() => showToast('Código copiado!', 'success'))" class="btn btn--primary btn--block">
                <i class="fas fa-copy"></i> Copiar código PIX
            </button>
            <p style="color:#888;font-size:0.78rem;margin-top:1rem">Válido por 30 minutos</p>
        </div>
    }

    <div style="background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:1.5rem;margin:2rem 0;text-align:left">
        <h3 style="margin-bottom:1rem;font-size:1rem">Resumo do pedido</h3>
        <div style="display:flex;flex-direction:column;gap:0.5rem">
            <div class="summary-row"><span>Subtotal</span><span>R$ @order.Subtotal.ToString("N2")</span></div>
            @if (order.Desconto > 0) { <div class="summary-row summary-row--discount"><span>Desconto</span><span>- R$ @order.Desconto.ToString("N2")</span></div> }
            <div class="summary-row"><span>Frete</span><span>@(order.Frete == 0 ? "Grátis" : "R$ " + order.Frete.ToString("N2"))</span></div>
            <div class="summary-row summary-row--total"><span>Total</span><span>R$ @order.Total.ToString("N2")</span></div>
        </div>
    </div>

    <p style="color:#888;margin-bottom:2rem">
        Você receberá um e-mail de confirmação em <strong>@order.EmailCliente</strong>
    </p>

    <div class="success-actions">
        <a href="/minha-conta/pedidos/@order.Id" class="btn btn--primary btn--lg">Ver meu pedido</a>
        <a href="/Products/Index" class="btn btn--ghost btn--lg">Continuar comprando</a>
    </div>
</div>
