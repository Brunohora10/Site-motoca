@model EssenzStore.Models.Product
@{
    var preco = Model.PrecoAtual;
    var fallbackProductImage = "https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=900&q=80";
    var img = Model.MainImage?.Url ?? fallbackProductImage;
    var desconto = Model.PercentualDesconto ?? 0;
    var hasVariants = Model.Variants?.Any() ?? false;
    var tamanhos = (Model.Variants ?? new List<EssenzStore.Models.ProductVariant>())
        .Where(v => v.Ativo && v.Estoque > 0)
        .Select(v => v.Tamanho)
        .Where(t => !string.IsNullOrEmpty(t))
        .Distinct()
        .Take(6)
        .ToList();
    var emEstoque = (Model.Variants?.Any(v => v.Ativo && v.Estoque > 0) ?? false) || !hasVariants;
    var freteGratis = preco >= 299m;
}
<div class="product-card">
    <a href="/produto/@Model.Slug" class="product-card__img-link">
        <img src="@img" alt="@Model.Nome" loading="lazy" decoding="async" class="product-card__img" onerror="this.onerror=null;this.src='@fallbackProductImage';" />

        @* Badges *@
        @if (desconto > 0)
        {
            <span class="product-card__badge product-card__badge--sale">-@desconto%</span>
        }
        else if (Model.Lancamento)
        {
            <span class="product-card__badge product-card__badge--new">Novo</span>
        }

        @if (freteGratis)
        {
            <span class="product-card__frete">Frete grátis</span>
        }

        @if (!emEstoque)
        {
            <div class="product-card__esgotado"><span>Esgotado</span></div>
        }

        @* Tamanhos no hover *@
        @if (tamanhos.Any())
        {
            <div class="product-card__sizes">
                @foreach (var tam in tamanhos)
                {
                    <button type="button" class="product-card__size-btn" onclick="quickAddSize(event,@Model.Id,'@tam')">@tam</button>
                }
            </div>
        }
        else
        {
            <div class="product-card__overlay">
                <button type="button" class="product-card__quick-add" data-product-id="@Model.Id" title="Adicionar ao carrinho">
                    <i class="fas fa-shopping-bag"></i>
                </button>
                <button type="button" class="product-card__wishlist" data-product-id="@Model.Id" title="Favoritar">
                    <i class="far fa-heart"></i>
                </button>
            </div>
        }
    </a>

    <div class="product-card__info">
        @if (Model.Brand != null)
        {
            <span class="product-card__brand">@Model.Brand.Nome</span>
        }
        <a href="/produto/@Model.Slug" class="product-card__name">@Model.Nome</a>
        <div class="product-card__price">
            @if (Model.PrecoPromocional.HasValue)
            {
                <span class="price__old">R$ @Model.Preco.ToString("N2")</span>
            }
            <span class="price__current">R$ @preco.ToString("N2")</span>
        </div>
        <span class="product-card__installment">6x de R$ @((preco / 6).ToString("N2")) sem juros</span>
    </div>

    @if (emEstoque)
    {
        <button type="button" class="product-card__buy" data-product-id="@Model.Id">
            <i class="fas fa-shopping-bag"></i> Comprar
        </button>
    }
    else
    {
        <a href="/produto/@Model.Slug" class="product-card__buy" style="background:var(--bg3);color:var(--text2)">
            Ver detalhes
        </a>
    }
</div>
